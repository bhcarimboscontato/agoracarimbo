---
import Icon from "@components/ui/Icon.astro";
import { createWhatsAppUrl } from "@lib/whatsapp";

const medicalWhatsappUrl = createWhatsAppUrl("Olá! Vim pelo site e quero informações sobre carimbo médico pelo fluxo do CRM-MG.");
---

<section class="crm-highlight" aria-labelledby="home-crm-title">
  <div class="container crm-highlight__inner">
    <div class="crm-highlight__logo" aria-label="CRM-MG">
      <img src="/assets/logo/crm-logo.png" alt="CRM-MG" width="220" height="86" loading="lazy" decoding="async" />
    </div>

    <div class="crm-highlight__copy">
      <p class="crm-highlight__eyebrow">Diferencial para médicos em Minas Gerais</p>
      <h2 id="home-crm-title">Credenciada no Controle Eletrônico de Carimbo do CRM-MG</h2>
      <p>
        Atendimento preparado para carimbos profissionais solicitados pelo fluxo do CRM-MG, com
        orientação pelo WhatsApp.
      </p>
    </div>

    <div class="crm-highlight__actions">
      <a class="crm-highlight__button crm-highlight__button--primary" href="/carimbo-medico-bh/">
        Ver carimbo médico
      </a>
      <a class="crm-highlight__button crm-highlight__button--secondary" href="/nossos-produtos/">
        Conhecer modelos
      </a>
      <a class="crm-highlight__whatsapp" href={medicalWhatsappUrl} target="_blank" rel="noopener noreferrer">
        <Icon name="icon-whatsapp" size="sm" />
        <span>Orientação para médicos</span>
      </a>
    </div>
  </div>
</section>

<style>
  .crm-highlight {
    min-height: clamp(13rem, 30vh, 19rem);
    display: grid;
    align-items: center;
    border-bottom: 1px solid rgb(249 115 22 / 22%);
    color: var(--color-white);
    background:
      linear-gradient(90deg, rgb(249 115 22 / 16%), transparent 28%, rgb(249 115 22 / 8%)),
      linear-gradient(180deg, #111, #1b1b1b);
  }

  .crm-highlight__inner {
    display: grid;
    grid-template-columns: minmax(10rem, 0.34fr) minmax(0, 1fr) minmax(16rem, 0.42fr);
    gap: clamp(1rem, 4vw, 2.5rem);
    align-items: center;
    padding-block: clamp(1.25rem, 3vw, 2rem);
  }

  .crm-highlight__logo {
    display: grid;
    min-height: 7.5rem;
    place-items: center;
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    background: rgb(255 255 255 / 94%);
  }

  .crm-highlight__logo img {
    width: min(100%, 13rem);
    height: auto;
    object-fit: contain;
  }

  .crm-highlight__eyebrow {
    margin: 0 0 var(--space-2);
    color: var(--color-orange-100);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .crm-highlight h2 {
    max-width: 24ch;
    margin: 0;
    color: var(--color-white);
    font-size: clamp(1.6rem, 3vw, 2.6rem);
    letter-spacing: 0;
    line-height: 1.06;
  }

  .crm-highlight__copy > p:last-child {
    max-width: 48rem;
    margin: var(--space-3) 0 0;
    color: rgb(255 255 255 / 82%);
    line-height: 1.55;
  }

  .crm-highlight__actions {
    display: grid;
    gap: var(--space-2);
  }

  .crm-highlight__button,
  .crm-highlight__whatsapp {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    border-radius: var(--radius-sm);
    padding: 0.75rem 0.95rem;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    line-height: 1.15;
    text-align: center;
    text-decoration: none;
  }

  .crm-highlight__button--primary {
    color: var(--color-white);
    background: var(--color-orange-600);
  }

  .crm-highlight__button--secondary,
  .crm-highlight__whatsapp {
    border: 1px solid rgb(255 255 255 / 22%);
    color: var(--color-white);
    background: rgb(255 255 255 / 7%);
  }

  .crm-highlight__whatsapp :global(.site-icon) {
    filter: brightness(0) invert(1);
  }

  @media (hover: hover) {
    .crm-highlight__button:hover,
    .crm-highlight__whatsapp:hover {
      transform: translateY(-1px);
    }
  }

  @media (max-width: 62rem) {
    .crm-highlight__inner {
      grid-template-columns: minmax(8rem, 0.35fr) minmax(0, 1fr);
    }

    .crm-highlight__actions {
      grid-column: 1 / -1;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 42rem) {
    .crm-highlight {
      min-height: auto;
    }

    .crm-highlight__inner {
      grid-template-columns: 1fr;
      padding-block: var(--space-5);
    }

    .crm-highlight__logo {
      min-height: 6rem;
    }

    .crm-highlight__actions {
      grid-template-columns: 1fr;
    }
  }
</style>
