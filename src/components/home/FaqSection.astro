---
import SectionHeader from "@components/home/SectionHeader.astro";
import { homeFaqs } from "@data/home";
---

<section class="home-section faq-section">
  <div class="container faq-wrap">
    <div class="faq-heading">
      <SectionHeader
        eyebrow="Perguntas frequentes"
        title="Dúvidas comuns antes de pedir"
        description="Respostas rápidas para quem quer resolver pelo WhatsApp."
      />
    </div>

    <div class="faq-list" aria-label="Perguntas frequentes da BH Carimbos">
      {homeFaqs.map((faq) => (
        <details class="faq-item" data-faq-item>
          <summary data-faq-summary>
            <span>{faq.question}</span>
            <span class="faq-item__indicator" aria-hidden="true"></span>
          </summary>

          <div class="faq-item__answer" data-faq-answer>
            <div class="faq-item__answer-inner">
              <p>{faq.answer}</p>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  const faqItems = document.querySelectorAll<HTMLDetailsElement>("[data-faq-item]");

  faqItems.forEach((item) => {
    const summary = item.querySelector<HTMLElement>("[data-faq-summary]");
    const answer = item.querySelector<HTMLElement>("[data-faq-answer]");

    if (!summary || !answer) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const transitionDuration = 320;

    if (item.open) {
      answer.style.maxHeight = "none";
    }

    summary.addEventListener("click", (event) => {
      event.preventDefault();

      const isOpen = item.open;

      if (reduceMotion) {
        item.open = !isOpen;
        answer.style.maxHeight = item.open ? "none" : "0px";
        return;
      }

      if (isOpen) {
        answer.style.maxHeight = `${answer.scrollHeight}px`;

        requestAnimationFrame(() => {
          answer.style.maxHeight = "0px";
        });

        window.setTimeout(() => {
          item.open = false;
        }, transitionDuration);

        return;
      }

      item.open = true;
      answer.style.maxHeight = "0px";

      requestAnimationFrame(() => {
        answer.style.maxHeight = `${answer.scrollHeight}px`;
      });
    });

    answer.addEventListener("transitionend", (event) => {
      if (event.propertyName !== "max-height") return;

      if (item.open) {
        answer.style.maxHeight = "none";
      }
    });
  });
</script>

<style>
  .faq-section {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 18% 18%, rgb(249 115 22 / 6%), transparent 22rem),
      linear-gradient(180deg, var(--color-white), var(--color-gray-50));
  }

  .faq-section::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgb(17 17 17 / 2.4%) 1px, transparent 1px),
      linear-gradient(180deg, rgb(17 17 17 / 1.8%) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(180deg, transparent, #000 18%, #000 82%, transparent);
  }

  .faq-wrap {
    position: relative;
    z-index: 1;
    display: grid;
    gap: clamp(1.75rem, 4vw, 3rem);
  }

  .faq-heading {
    max-width: 48rem;
  }

  .faq-heading :global(.section-header) {
    margin: 0;
  }

  .faq-list {
    display: grid;
    width: min(100%, 58rem);
    gap: var(--space-4);
  }

  .faq-item {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(17 17 17 / 12%);
    border-radius: var(--radius-md);
    background: rgb(255 255 255 / 94%);
    box-shadow: 0 10px 28px rgb(17 17 17 / 4%);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .faq-item:hover {
    border-color: rgb(249 115 22 / 28%);
    background: var(--color-white);
    box-shadow: 0 14px 34px rgb(17 17 17 / 6%);
    transform: translateY(-1px);
  }

  .faq-item[open] {
    border-color: rgb(17 17 17 / 14%);
    background: var(--color-white);
    box-shadow: 0 14px 34px rgb(17 17 17 / 6%);
  }

  .faq-item summary {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-4);
    align-items: center;
    min-height: 4.1rem;
    padding: var(--space-4) var(--space-5);
    list-style: none;
    color: var(--color-black);
    cursor: pointer;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::marker {
    content: "";
  }

  .faq-item summary span:first-child {
    color: var(--color-black);
    font-weight: var(--font-weight-bold);
    line-height: 1.28;
    transition: color 180ms ease;
  }

  .faq-item summary:hover span:first-child,
  .faq-item[open] summary span:first-child {
    color: var(--color-orange-700);
  }

  .faq-item__indicator {
    position: relative;
    display: grid;
    width: 2.1rem;
    height: 2.1rem;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid rgb(17 17 17 / 16%);
    border-radius: var(--radius-sm);
    background: rgb(249 115 22 / 8%);
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .faq-item__indicator::before,
  .faq-item__indicator::after {
    content: "";
    position: absolute;
    width: 0.82rem;
    height: 2px;
    background: var(--color-orange-700);
    transition:
      background-color 180ms ease,
      transform 180ms ease;
  }

  .faq-item__indicator::after {
    transform: rotate(90deg);
  }

  .faq-item[open] .faq-item__indicator {
    border-color: var(--color-orange-600);
    background: var(--color-orange-600);
    transform: rotate(180deg);
  }

  .faq-item[open] .faq-item__indicator::before,
  .faq-item[open] .faq-item__indicator::after {
    background: var(--color-white);
  }

  .faq-item[open] .faq-item__indicator::after {
    transform: rotate(0deg);
  }

  .faq-item__answer {
    max-height: 0;
    overflow: hidden;
    border-top: 1px solid rgb(17 17 17 / 0%);
    background:
      linear-gradient(90deg, rgb(249 115 22 / 4%), transparent 38%),
      var(--color-gray-50);
    opacity: 0;
    transition:
      max-height 320ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 220ms ease,
      border-color 220ms ease;
  }

  .faq-item[open] .faq-item__answer {
    border-top-color: rgb(17 17 17 / 8%);
    opacity: 1;
  }

  .faq-item__answer-inner {
    padding: var(--space-4) var(--space-5) var(--space-5);
  }

  .faq-item__answer p {
    max-width: 48rem;
    margin: 0;
    color: var(--color-gray-700);
    font-size: clamp(0.95rem, 1.05vw, 1.02rem);
    line-height: 1.72;
  }

  @media (min-width: 64rem) {
    .faq-list {
      margin-inline: auto 0;
    }
  }

  @media (max-width: 47.99rem) {
    .faq-wrap {
      gap: var(--space-6);
    }

    .faq-list {
      gap: var(--space-3);
    }

    .faq-item summary {
      min-height: 3.85rem;
      gap: var(--space-3);
      padding: var(--space-4);
    }

    .faq-item__indicator {
      width: 1.9rem;
      height: 1.9rem;
    }

    .faq-item__answer-inner {
      padding: var(--space-4);
    }

    .faq-item__answer p {
      line-height: 1.65;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item,
    .faq-item summary span:first-child,
    .faq-item__indicator,
    .faq-item__indicator::before,
    .faq-item__indicator::after,
    .faq-item__answer {
      transition: none;
    }

    .faq-item:hover {
      transform: none;
    }
  }
</style>