---
import BenefitCard from "@components/home/BenefitCard.astro";
import Icon from "@components/ui/Icon.astro";
import PaymentMethodsStrip from "@components/home/PaymentMethodsStrip.astro";
import { benefits, paymentMethods } from "@data/home";
---

<section class="home-section benefits-section">
  <div class="container">
    <div class="benefits-section__header">
      <div class="benefits-section__copy">
        <p class="section-eyebrow">ATENDIMENTO PRÁTICO</p>
        <h2>Pedido simples, produção local e orientação direta.</h2>
        <p>
          Você envia os dados, recebe orientação pelo WhatsApp e acompanha a aprovação antes da produção.
        </p>
      </div>
      <aside class="benefits-section__whatsapp" aria-label="Atendimento pelo WhatsApp">
        <span class="benefits-section__whatsapp-icon">
          <Icon name="icon-whatsapp" size="xl" />
        </span>
        <strong>Peça pelo WhatsApp</strong>
        <span>Resposta rápida e atendimento direto.</span>
      </aside>
    </div>
    <div class="benefits-grid">
      {benefits.map((benefit, index) => <BenefitCard {...benefit} index={index} />)}
    </div>
    <PaymentMethodsStrip {...paymentMethods} />
  </div>
</section>

<style>
  .benefits-section {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 12%, rgb(249 115 22 / 7%), transparent 24rem),
      linear-gradient(180deg, var(--color-white) 0%, rgb(250 250 249 / 78%) 100%);
  }

  .benefits-section::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(90deg, rgb(17 17 17 / 2.2%) 1px, transparent 1px),
      linear-gradient(180deg, rgb(17 17 17 / 1.8%) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(180deg, black 0%, transparent 58%);
  }

  .benefits-section .container {
    position: relative;
    z-index: 1;
  }

  .benefits-section__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 22rem);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .benefits-section__copy {
    max-width: 52rem;
  }

  .benefits-section__copy .section-eyebrow {
    justify-content: flex-start;
    margin-bottom: var(--space-4);
  }

  .benefits-section__copy h2 {
    max-width: 46rem;
    margin: 0;
    font-size: clamp(2.25rem, 4.7vw, 4.15rem);
    line-height: 1.06;
    letter-spacing: 0;
  }

  .benefits-section__copy > p:last-child {
    max-width: 42rem;
    margin: var(--space-5) 0 0;
    color: var(--color-gray-700);
    font-size: clamp(1.05rem, 1.5vw, 1.35rem);
    line-height: 1.58;
  }

  .benefits-section__whatsapp {
    position: relative;
    display: grid;
    min-height: 230px;
    place-items: center;
    align-content: center;
    gap: var(--space-3);
    border: 1px solid rgb(249 115 22 / 18%);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    overflow: hidden;
    text-align: center;
    background:
      radial-gradient rgb(255 255 255 / 98% 0 38%, rgb(255 247 237 / 72%) 39% 100%),
      var(--color-white);
    box-shadow: 0 18px 48px rgb(17 17 17 / 6%);
  }

  .benefits-section__halo {
    content: "";
    position: absolute;
    inset: 18%;
    border: 1px solid rgb(249 115 22 / 10%);
    border-radius: 50%;
  }

  .benefits-section__whatsapp-icon,
  .benefits-section__whatsapp strong,
  .benefits-section__whatsapp span:not(.benefits-section__halo) {
    position: relative;
    z-index: 1;
  }

  .benefits-section__whatsapp-icon {
    display: grid;
    width: 74px;
    height: 74px;
    place-items: center;
    border-radius: 50%;
    color: var(--color-orange-600);
    background: rgb(255 255 255 / 86%);
  }

  .benefits-section__whatsapp-icon :global(.site-icon) {
    filter: none;
  }

  .benefits-section__whatsapp strong {
    color: var(--color-orange-600);
    font-size: var(--text-xl);
    line-height: 1.12;
  }

  .benefits-section__whatsapp span:not(.benefits-section__halo) {
    max-width: 15rem;
    color: var(--color-gray-800);
    font-weight: var(--font-weight-semibold);
  }

  .benefits-grid {
    position: relative;
    display: grid;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  @media (max-width: 63.99rem) {
    .benefits-section__header {
      grid-template-columns: 1fr;
    }

    .benefits-section__whatsapp {
      min-height: 210px;
    }

    .benefits-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 50rem) {
    .benefits-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 40rem) {
    .benefits-section__header {
      margin-bottom: var(--space-7);
    }

    .benefits-section__copy h2 {
      font-size: clamp(2.1rem, 12vw, 3rem);
    }

    .benefits-section__whatsapp {
      min-height: 180px;
      padding: var(--space-5);
    }

    .benefits-grid {
      gap: var(--space-3);
      grid-template-columns: 1fr;
    }
  }
</style>
