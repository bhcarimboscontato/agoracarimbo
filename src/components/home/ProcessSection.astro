---
import Icon from "@components/ui/Icon.astro";
import { processAssurances, processSteps } from "@data/home";

const primaryStep = processSteps[0];
const secondarySteps = processSteps.slice(1);
---

<section class="home-section process-section">
  <div class="container">
    <div class="process-layout">
      <div class="process-copy">
        <p class="section-eyebrow">COMO FUNCIONA</p>
        <h2>Três passos para pedir seu carimbo</h2>
        <p>O processo foi pensado para resolver rápido, sem formulário longo e sem complicação.</p>
      </div>

      <div class="process-flow" aria-label="Passos para pedir carimbo">
  {
    primaryStep && (
      <article class="process-card process-card--primary">
        <div class="process-card__topline process-card__topline--primary">
  <span class="process-card__number">01</span>

  <span class="process-card__icon process-card__icon--primary" aria-hidden="true">
    <Icon name={primaryStep.icon} size="lg" />
  </span>
</div>

        <div class="process-card__content">
          <h3>{primaryStep.title}</h3>
          <p>{primaryStep.description}</p>
        </div>
      </article>
    )
  }

        <div class="process-connector" aria-hidden="true">
          <span></span>
          <i></i>
          <span></span>
        </div>

        <div class="process-side-cards">
          {
            secondarySteps.map((step, index) => (
              <article class="process-card process-card--side">
                <div class="process-card__topline">
                  <span class="process-card__number">{String(index + 2).padStart(2, "0")}</span>
                  <span class="process-card__icon" aria-hidden="true">
                    <Icon name={step.icon} size="lg" />
                  </span>
                </div>

                <div class="process-card__content">
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>

    <ul class="process-assurances" aria-label="Garantias do processo">
      {
        processAssurances.map((item) => (
          <li>
            <span class="process-assurances__icon" aria-hidden="true">
              <Icon name={item.icon} size="lg" />
            </span>
            <span class="process-assurances__content">
              <strong>{item.title}</strong>
              <em>{item.description}</em>
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .process-section {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 84% 15%, rgb(249 115 22 / 7%), transparent 28rem),
      radial-gradient(circle at 8% 88%, rgb(249 115 22 / 4%), transparent 22rem),
      linear-gradient(180deg, var(--color-white), var(--color-gray-50));
  }

  .process-section::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgb(17 17 17 / 3%) 1px, transparent 1px),
      linear-gradient(180deg, rgb(17 17 17 / 3%) 1px, transparent 1px);
    background-size: 54px 54px;
    mask-image: linear-gradient(180deg, transparent, #000 18%, #000 82%, transparent);
    opacity: 0.32;
  }

  .process-section > .container {
    position: relative;
    z-index: 1;
  }

  .process-layout {
    display: grid;
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: center;
  }

  .process-copy {
    max-width: 34rem;
  }

  .process-copy .section-eyebrow {
    justify-content: flex-start;
    margin-bottom: var(--space-4);
  }

  .process-copy .section-eyebrow::after {
    content: "";
    display: block;
    width: 54px;
    height: 3px;
    margin-top: var(--space-3);
    border-radius: 999px;
    background: var(--color-orange-600);
  }

  .process-copy h2 {
  max-width: 14ch;
  margin: 0 0 var(--space-5);
  color: var(--color-black);
  font-size: clamp(2.35rem, 4.15vw, 4.05rem);
  line-height: 1.06;
  letter-spacing: -0.045em;
}

  .process-copy p:last-child {
    max-width: 27rem;
    margin: 0;
    color: var(--color-gray-700);
    font-size: clamp(1.03rem, 1.35vw, 1.22rem);
    line-height: 1.75;
  }

  .process-flow {
    position: relative;
    display: grid;
    gap: clamp(1rem, 2vw, 1.75rem);
  }

  .process-side-cards {
  display: grid;
  gap: clamp(1rem, 1.6vw, 1.35rem);
  align-content: center;
}

  .process-card {
    position: relative;
    display: grid;
    border: 1px solid rgb(17 17 17 / 10%);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 96%), rgb(255 255 255 / 90%)),
      var(--color-white);
    box-shadow: 0 18px 45px rgb(17 17 17 / 7%);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .process-card__topline--primary {
  justify-content: flex-start;
  gap: var(--space-4);
  align-items: center;
}

  .process-card:hover {
    transform: translateY(-3px);
    border-color: rgb(249 115 22 / 28%);
    box-shadow: 0 24px 58px rgb(17 17 17 / 10%);
  }

  .process-card--primary {
  min-height: 24rem;
  align-content: center;
  gap: clamp(1rem, 1.6vw, 1.45rem);
  padding: clamp(1.4rem, 2.4vw, 2.25rem);
}

  .process-card--side {
  min-height: auto;
  gap: var(--space-4);
  align-content: start;
  padding: clamp(1.15rem, 1.7vw, 1.55rem);
}

  .process-card__topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .process-card--primary .process-card__topline,
.process-card__topline--primary {
  width: 100%;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-4);
}

.process-card__icon--primary {
  width: 5.8rem;
  height: 5.8rem;
}

  .process-card__number {
    display: grid;
    width: 4.3rem;
    height: 4.3rem;
    place-items: center;
    border: 1px solid rgb(249 115 22 / 22%);
    border-radius: 50%;
    color: var(--color-orange-700);
    font-size: clamp(1.35rem, 2vw, 2rem);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    background: rgb(255 255 255 / 86%);
  }

  .process-card__icon {
  display: grid;
  width: 4.6rem;
  height: 4.6rem;
  place-items: center;
  border-radius: 50%;
  color: var(--color-orange-600);
  background:
    radial-gradient(circle at 50% 42%, rgb(249 115 22 / 13%), rgb(249 115 22 / 7%) 64%, transparent 65%),
    rgb(249 115 22 / 5%);
}

.process-card--side .process-card__icon {
  width: 4.15rem;
  height: 4.15rem;
}

.process-card--primary .process-card__icon {
  width: 5.8rem;
  height: 5.8rem;
}

  .process-card__icon :global(.site-icon),
  .process-assurances__icon :global(.site-icon) {
    filter: brightness(0) saturate(100%) invert(46%) sepia(89%) saturate(1554%) hue-rotate(352deg) brightness(97%) contrast(91%);
  }

  .process-card__content {
    display: grid;
    gap: var(--space-4);
  }

  .process-card h3 {
  max-width: 13.5ch;
  margin: 0;
  color: var(--color-black);
  font-size: clamp(1.45rem, 2.25vw, 2.05rem);
  line-height: 1.08;
  letter-spacing: -0.04em;
}

.process-card--side h3 {
  max-width: 14ch;
  font-size: clamp(1.25rem, 1.55vw, 1.55rem);
  line-height: 1.08;
}

  .process-card p {
    max-width: 24rem;
    margin: 0;
    color: var(--color-gray-700);
    font-size: clamp(0.98rem, 1.2vw, 1.08rem);
    line-height: 1.65;
  }

  .process-card--side p {
  font-size: clamp(0.92rem, 1vw, 1rem);
  line-height: 1.55;
}

  .process-connector {
    display: none;
  }

  .process-assurances {
    display: grid;
    gap: 0;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    border: 1px solid rgb(249 115 22 / 18%);
    border-radius: var(--radius-lg);
    overflow: hidden;
    padding: 0;
    list-style: none;
    background: rgb(255 255 255 / 78%);
    box-shadow: 0 16px 40px rgb(17 17 17 / 4%);
  }

  .process-assurances li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: center;
    padding: clamp(1.05rem, 2vw, 1.5rem);
    background: rgb(255 255 255 / 82%);
  }

  .process-assurances li + li {
    border-top: 1px solid rgb(17 17 17 / 9%);
  }

  .process-assurances__icon {
    display: grid;
    width: 3.9rem;
    height: 3.9rem;
    place-items: center;
    border: 1px solid rgb(249 115 22 / 22%);
    border-radius: 50%;
    color: var(--color-orange-600);
    background: rgb(255 255 255 / 90%);
  }

  .process-assurances__content {
    display: grid;
    gap: 0.15rem;
  }

  .process-assurances strong,
  .process-assurances em {
    display: block;
  }

  .process-assurances strong {
    color: var(--color-black);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
  }

  .process-assurances em {
    margin: 0;
    color: var(--color-gray-700);
    font-style: normal;
    font-size: var(--text-sm);
    line-height: 1.35;
  }

  @media (min-width: 64rem) {
  .process-layout {
    grid-template-columns: minmax(20rem, 0.82fr) minmax(0, 1.55fr);
    gap: clamp(2.5rem, 4vw, 4.25rem);
  }

  .process-flow {
  grid-template-columns: minmax(20rem, 1fr) 2rem minmax(23rem, 1.15fr);
  align-items: center;
}

  .process-card--primary {
  min-height: 27rem;
}

  .process-connector {
    position: relative;
    display: grid;
    justify-items: center;
    align-self: center;
    height: 17.5rem;
  }

  .process-connector i {
    display: block;
    width: 1px;
    height: 100%;
    background: linear-gradient(180deg, transparent, rgb(249 115 22 / 36%), transparent);
  }

  .process-connector span {
    position: absolute;
    left: 50%;
    display: block;
    width: 9px;
    height: 9px;
    border: 2px solid var(--color-white);
    border-radius: 50%;
    background: var(--color-orange-600);
    box-shadow: 0 0 0 4px rgb(249 115 22 / 10%);
    transform: translateX(-50%);
  }

  .process-connector span:first-child {
    top: 0;
  }

  .process-connector span:last-child {
    bottom: 0;
  }

  .process-assurances {
    grid-template-columns: repeat(4, 1fr);
  }

  .process-assurances li + li {
    border-top: 0;
    border-left: 1px solid rgb(17 17 17 / 10%);
  }
}

  @media (min-width: 48rem) and (max-width: 63.99rem) {
    .process-layout {
      grid-template-columns: 1fr;
    }

    .process-copy {
      max-width: 42rem;
    }

    .process-copy h2 {
      max-width: 13ch;
    }

    .process-flow {
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
    }

    .process-card--primary {
      min-height: 100%;
    }

    .process-side-cards {
      min-height: 100%;
    }

    .process-assurances {
      grid-template-columns: repeat(2, 1fr);
    }

    .process-assurances li:nth-child(2) {
      border-top: 0;
    }

    .process-assurances li:nth-child(2n) {
      border-left: 1px solid rgb(17 17 17 / 10%);
    }
  }

  @media (max-width: 47.99rem) {
    .process-section::before {
      background-size: 42px 42px;
      opacity: 0.18;
    }

    .process-layout {
      gap: var(--space-8);
    }

    .process-copy h2 {
      max-width: 11ch;
      font-size: clamp(2.65rem, 13vw, 3.55rem);
      letter-spacing: -0.06em;
    }

    .process-flow {
      gap: var(--space-4);
    }

    .process-card,
    .process-card--primary,
    .process-card--side {
      min-height: auto;
      gap: var(--space-5);
      padding: var(--space-5);
    }

    .process-card--primary .process-card__icon,
    .process-card__icon {
      width: 4.8rem;
      height: 4.8rem;
    }

    .process-card__number {
      width: 3.65rem;
      height: 3.65rem;
      font-size: var(--text-xl);
    }

    .process-card h3,
    .process-card--side h3 {
      max-width: 13ch;
      font-size: clamp(1.65rem, 7vw, 2.15rem);
    }

    .process-assurances {
      margin-top: var(--space-6);
    }
  }

  @media (max-width: 26rem) {
    .process-assurances li {
      grid-template-columns: 1fr;
    }
  }
</style>
