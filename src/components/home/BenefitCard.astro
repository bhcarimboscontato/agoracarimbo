---
import Icon from "@components/ui/Icon.astro";

type Props = {
  title: string;
  description: string;
  icon: string;
  index: number;
};

const { title, description, icon, index } = Astro.props;
const number = String(index + 1).padStart(2, "0");
---

<article class="benefit-card">
  <div class="benefit-card__top">
    <span class="benefit-card__icon"><Icon name={icon} size="lg" /></span>
    <span class="benefit-card__number">{number}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
</article>

<style>
  .benefit-card {
    position: relative;
    display: grid;
    align-content: start;
    gap: var(--space-5);
    min-height: 252px;
    border: 1px solid rgb(17 17 17 / 10%);
    border-radius: var(--radius-lg);
    padding: clamp(1.25rem, 2vw, 1.65rem);
    overflow: hidden;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 96%), rgb(255 255 255 / 88%)),
      var(--color-white);
    box-shadow: 0 16px 34px rgb(17 17 17 / 5%);
    transition: border-color 160ms ease, transform 160ms ease, background-color 160ms ease, box-shadow 160ms ease;
  }

  .benefit-card:hover {
    transform: translateY(-2px);
    border-color: rgb(249 115 22 / 38%);
    background:
      linear-gradient(180deg, var(--color-white), rgb(255 247 237 / 58%)),
      var(--color-white);
    box-shadow: 0 18px 42px rgb(17 17 17 / 8%);
  }

  .benefit-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .benefit-card__icon {
    display: inline-grid;
    width: 58px;
    height: 58px;
    place-items: center;
    border: 1px solid rgb(17 17 17 / 10%);
    border-radius: var(--radius-md);
    color: var(--color-black);
    background:
      linear-gradient(135deg, rgb(249 115 22 / 12%), rgb(255 247 237 / 56%)),
      rgb(255 255 255 / 92%);
  }

  .benefit-card :global(.site-icon) {
    color: currentColor;
    filter: brightness(0);
  }

  .benefit-card__number {
    display: inline-grid;
    min-width: 2.25rem;
    min-height: 1.85rem;
    place-items: center;
    border: 1px solid rgb(249 115 22 / 26%);
    border-radius: var(--radius-sm);
    color: var(--color-orange-800);
    background: var(--color-orange-50);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1;
  }

  .benefit-card h3 {
    margin: 0;
    max-width: 11rem;
    font-size: clamp(1.2rem, 1.7vw, 1.5rem);
    line-height: 1.16;
  }

  .benefit-card p {
    margin: 0;
    color: var(--color-gray-700);
    font-size: 0.96rem;
    line-height: 1.62;
  }

  @media (max-width: 40rem) {
    .benefit-card {
      min-height: auto;
      padding-bottom: var(--space-8);
    }

    .benefit-card__icon {
      width: 56px;
      height: 56px;
    }

    .benefit-card h3 {
      max-width: none;
    }
  }
</style>
