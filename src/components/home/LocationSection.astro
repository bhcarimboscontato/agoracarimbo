---
import ButtonLink from "@components/ui/ButtonLink.astro";
import Icon from "@components/ui/Icon.astro";
import { servedRegions } from "@data/home";
import { businessInfo } from "@data/site";
import { getWhatsAppUrl } from "@lib/whatsapp";

const addressLines = [
  businessInfo.address.street,
  `Bairro ${businessInfo.address.neighborhood}, ${businessInfo.address.region}, ${businessInfo.address.city}/${businessInfo.address.state}`
];

const openingHoursLines = [
  businessInfo.openingHours.weekdays,
  businessInfo.openingHours.saturday
];
---

<section id="localizacao-entrega" class="home-section location-section">
  <div class="container location-layout">
    <div class="location-copy">
      <p class="location-eyebrow">
        <Icon name="icon-company" size="xs" />
        <span>Localização e entrega</span>
      </p>

      <h2>
        Loja em Venda Nova.<br />
        Entrega rápida em BH.
      </h2>

      <p class="location-description">
        Visite nossa loja ou receba seu pedido com rapidez e segurança por motoboy em Belo Horizonte e região.
      </p>

      <div class="location-actions">
        <ButtonLink href={businessInfo.googleMapsRouteUrl} label="Ver rota no Google Maps" variant="secondary" external>
          <Icon name="icon-company" size="sm" />
        </ButtonLink>
        <ButtonLink href={getWhatsAppUrl("delivery")} label="Pedir entrega pelo WhatsApp" external>
          <Icon name="icon-whatsapp" size="sm" />
        </ButtonLink>
      </div>

      <div class="location-map-detail" aria-hidden="true">
        <span class="location-map-detail__start"></span>
        <span class="location-map-detail__pin">
          <Icon name="icon-map-pin" size="md" />
        </span>
      </div>
    </div>

    <div class="location-divider" aria-hidden="true"></div>

    <aside class="location-details" aria-label="Informações da loja e regiões atendidas">
      <p class="location-badge">
        <Icon name="icon-stamp" size="sm" />
        <span>Loja física</span>
      </p>

      <div class="location-info-list">
        <div class="location-info-item">
          <Icon name="icon-company" size="md" />
          <p>
            {addressLines.map((line) => <span>{line}</span>)}
          </p>
        </div>

        <div class="location-info-item">
          <Icon name="icon-fast" size="md" />
          <p>
            {openingHoursLines.map((line) => <span>{line}</span>)}
          </p>
        </div>

        <div class="location-info-item">
          <Icon name="icon-delivery" size="md" />
          <p>
            <span>Entrega por motoboy em Belo Horizonte e região.</span>
          </p>
        </div>
      </div>

      <div class="location-regions">
        <h3>Regiões de atendimento</h3>
        <div class="location-region-grid" aria-label="Regiões atendidas para entrega e atendimento">
          {servedRegions.map((region) => <span class="location-region-chip">{region}</span>)}
        </div>
      </div>
    </aside>
  </div>
</section>

<style>
  .location-section {
    scroll-margin-top: calc(var(--header-height) + 2rem);
    overflow: hidden;
    background:
      radial-gradient(circle at 38% 76%, rgb(249 115 22 / 5%), transparent 24rem),
      linear-gradient(180deg, var(--color-white) 0%, rgb(250 250 249 / 96%) 100%);
  }

  .location-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-8);
  }

  .location-copy,
  .location-details {
    min-width: 0;
  }

  .location-copy {
    position: relative;
    display: grid;
    align-content: center;
    min-height: clamp(26rem, 42vw, 32rem);
    overflow: hidden;
    padding-block: var(--space-4);
  }

  .location-eyebrow {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    width: fit-content;
    margin: 0 0 var(--space-5);
    color: var(--color-orange-700);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.36em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .location-eyebrow :global(.site-icon),
  .location-badge :global(.site-icon),
  .location-map-detail__pin :global(.site-icon) {
    filter: brightness(0) saturate(100%) invert(46%) sepia(89%) saturate(1554%) hue-rotate(352deg) brightness(97%) contrast(91%);
  }

  .location-copy h2 {
    position: relative;
    z-index: 1;
    max-width: 13.5ch;
    margin: 0 0 var(--space-5);
    color: var(--color-black);
    font-size: clamp(2.25rem, 4.5vw, 3.95rem);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0;
    line-height: 1.14;
  }

  .location-description {
    position: relative;
    z-index: 1;
    max-width: 39rem;
    margin: 0 0 var(--space-8);
    color: var(--color-gray-700);
    font-size: clamp(1rem, 1.35vw, 1.18rem);
    line-height: 1.75;
  }

  .location-actions {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-4);
    width: min(100%, 28rem);
  }

  .location-actions :global(.button) {
    justify-content: flex-start;
    min-height: 58px;
    border-radius: var(--radius-sm);
    padding-inline: var(--space-6);
  }

  .location-actions :global(.button--secondary) {
    color: var(--color-gray-900);
    border-color: rgb(17 17 17 / 82%);
    background: rgb(255 255 255 / 76%);
  }

  .location-actions :global(.button--secondary:hover) {
    color: var(--color-white);
    border-color: var(--color-black);
    background: var(--color-black);
  }

  .location-actions :global(.button--secondary .site-icon) {
    filter: none;
  }

  .location-map-detail {
    position: absolute;
    right: 0;
    bottom: 0.25rem;
    width: min(43%, 22rem);
    height: 74%;
    pointer-events: none;
    opacity: 0.62;
  }

  .location-map-detail::before {
    content: "";
    position: absolute;
    inset: 8% 6% 4% 0;
    background:
      linear-gradient(116deg, transparent 0 43%, rgb(17 17 17 / 5%) 43.1% 43.6%, transparent 43.8%),
      linear-gradient(22deg, transparent 0 54%, rgb(249 115 22 / 9%) 54.1% 54.7%, transparent 54.9%),
      linear-gradient(82deg, transparent 0 61%, rgb(17 17 17 / 4%) 61.1% 61.5%, transparent 61.7%);
  }

  .location-map-detail::after {
    content: "";
    position: absolute;
    right: 6%;
    bottom: 13%;
    width: 78%;
    height: 42%;
    border-bottom: 2px dashed rgb(249 115 22 / 45%);
    border-left: 2px dashed rgb(249 115 22 / 45%);
    border-radius: 0 0 0 84px;
    transform: skewY(-9deg);
  }

  .location-map-detail__start {
    position: absolute;
    left: 2%;
    bottom: 7%;
    width: 1.45rem;
    height: 1.45rem;
    border-radius: 50%;
    background: rgb(249 115 22 / 38%);
  }

  .location-map-detail__pin {
    position: absolute;
    right: 5%;
    bottom: 50%;
    display: grid;
    width: 3.2rem;
    height: 3.2rem;
    place-items: center;
    border-radius: 50%;
    background: rgb(249 115 22 / 16%);
  }

  .location-details {
    display: grid;
    align-content: center;
    gap: var(--space-6);
  }

  .location-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    width: fit-content;
    margin: 0;
    border: 1px solid rgb(249 115 22 / 24%);
    border-radius: var(--radius-sm);
    padding: 0.72rem 1rem;
    color: var(--color-orange-800);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.22em;
    line-height: 1.2;
    text-transform: uppercase;
    background: var(--color-orange-50);
  }

  .location-info-list {
    display: grid;
  }

  .location-info-item {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: var(--space-5);
    align-items: start;
    border-bottom: 1px solid rgb(17 17 17 / 17%);
    padding: var(--space-5) 0;
  }

  .location-info-item:first-child {
    padding-top: 0;
  }

  .location-info-item :global(.site-icon) {
    display: block;
    width: 1.45rem;
    min-width: 1.45rem;
    max-width: 1.45rem;
    height: 1.45rem;
    min-height: 1.45rem;
    max-height: 1.45rem;
    margin-top: 0.1rem;
    filter: none;
  }

  .location-info-item p {
    display: grid;
    gap: 0.12rem;
    min-width: 0;
    margin: 0;
    color: var(--color-gray-800);
    font-size: clamp(1rem, 1.18vw, 1.13rem);
    line-height: 1.55;
  }

  .location-info-item span {
    overflow-wrap: anywhere;
  }

  .location-regions {
    min-width: 0;
  }

  .location-regions h3 {
    margin: 0 0 var(--space-4);
    color: var(--color-gray-800);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.24em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .location-region-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 0.75rem;
    max-width: 100%;
    min-width: 0;
  }

  .location-region-chip {
    display: inline-flex;
    max-width: 100%;
    align-items: center;
    border: 1px solid rgb(17 17 17 / 16%);
    border-radius: var(--radius-sm);
    padding: 0.48rem 0.75rem;
    color: var(--color-gray-800);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    line-height: 1.15;
    overflow-wrap: anywhere;
    background: rgb(255 255 255 / 72%);
  }

  .location-divider {
    display: none;
    width: 1px;
    min-height: 100%;
    background: rgb(17 17 17 / 26%);
  }

  @media (min-width: 64rem) {
    .location-layout {
      grid-template-columns: minmax(0, 0.48fr) 1px minmax(0, 0.52fr);
      gap: clamp(2.5rem, 4.6vw, 4rem);
      align-items: stretch;
    }

    .location-divider {
      display: block;
    }

    .location-details {
      padding-block: var(--space-4);
    }
  }

  @media (max-width: 63.99rem) {
    .location-copy {
      min-height: 25rem;
    }

    .location-layout {
      gap: var(--space-10);
    }

    .location-details {
      border-top: 1px solid rgb(17 17 17 / 14%);
      padding-top: var(--space-8);
    }

    .location-map-detail {
      width: min(48%, 18rem);
      opacity: 0.34;
    }
  }

  @media (max-width: 47.99rem) {
    .location-section {
      padding-block: var(--space-12);
    }

    .location-copy {
      min-height: auto;
      padding-block: 0;
    }

    .location-eyebrow {
      gap: var(--space-3);
      font-size: 0.76rem;
      letter-spacing: 0.18em;
    }

    .location-copy h2 {
      max-width: 12ch;
      font-size: clamp(2.05rem, 10vw, 3rem);
    }

    .location-description {
      font-size: var(--text-base);
    }

    .location-actions {
      width: 100%;
    }

    .location-actions :global(.button) {
      width: 100%;
      justify-content: center;
      min-height: 56px;
      padding-inline: var(--space-4);
    }

    .location-map-detail {
      display: none;
    }

    .location-info-item {
      grid-template-columns: 1.75rem minmax(0, 1fr);
      gap: var(--space-4);
      padding: var(--space-4) 0;
    }

    .location-info-item p {
      font-size: var(--text-base);
    }

    .location-region-grid {
      gap: var(--space-2);
    }

    .location-region-chip {
      font-size: 0.78rem;
    }
  }
</style>
