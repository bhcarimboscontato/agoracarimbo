---
import ProductCard from "@components/home/ProductCard.astro";
import Icon from "@components/ui/Icon.astro";
import { featuredProducts } from "@data/home";
---

<section id="produtos" class="home-section products-section">
  <div class="container">
    <div class="products-section__header">
      <p class="section-eyebrow">PRODUTOS MAIS PROCURADOS</p>
      <h2>Modelos para empresas, profissionais liberais e uso pessoal</h2>
      <p>Escolha um tipo de carimbo e chame no WhatsApp com a mensagem certa para o atendimento.</p>
    </div>

    <a class="products-catalog-callout" href="/nossos-produtos/">
      <span class="products-catalog-callout__media" aria-hidden="true">
        <img src="/assets/carimbos-produtos/Trodat-4911-Preto.jpeg" alt="" width="180" height="140" loading="lazy" decoding="async" />
      </span>
      <span class="products-catalog-callout__copy">
        <strong>Veja todos os modelos antes de pedir</strong>
        <span>Confira fotos, variações e detalhes dos carimbos automáticos, de madeira, profissionais, CNPJ e aplicações personalizadas.</span>
      </span>
      <span class="products-catalog-callout__cta">
        <Icon name="icon-stamp" size="sm" />
        Ver catálogo de produtos
      </span>
    </a>
    
    <div class="products-grid">
      {featuredProducts.map((product) => <ProductCard {...product} />)}
    </div>
  </div>
</section>

<style>
  .products-section {
    background:
      radial-gradient(circle at 82% 18%, rgb(249 115 22 / 5%), transparent 24rem),
      var(--color-white);
  }

  .products-section__header {
    max-width: 58rem;
    margin-bottom: var(--space-6);
  }

  .products-section__header .section-eyebrow {
    justify-content: flex-start;
    margin-bottom: var(--space-3);
  }

  .products-section__header .section-eyebrow::after {
    content: "";
    display: block;
    width: 42px;
    height: 2px;
    margin-top: var(--space-3);
    background: var(--color-orange-600);
  }

  .products-section__header h2 {
    max-width: 20ch;
    margin-bottom: var(--space-4);
    color: var(--color-black);
    font-size: clamp(2.35rem, 5vw, 4.65rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .products-section__header p:last-child {
    max-width: 42rem;
    margin: 0;
    color: var(--color-gray-700);
    font-size: clamp(1rem, 1.3vw, 1.18rem);
    line-height: 1.55;
  }

  .products-catalog-callout {
    display: grid;
    grid-template-columns: minmax(6rem, 9rem) minmax(0, 1fr) auto;
    gap: clamp(0.9rem, 2.5vw, 1.5rem);
    align-items: center;
    margin: 0 0 var(--space-6);
    border: 1px solid rgb(17 17 17 / 10%);
    border-left: 4px solid var(--color-orange-600);
    border-radius: var(--radius-md);
    padding: clamp(0.85rem, 2vw, 1.15rem);
    color: var(--color-black);
    text-decoration: none;
    background:
      linear-gradient(90deg, rgb(255 247 237 / 86%), var(--color-white)),
      var(--color-white);
    box-shadow: 0 14px 34px rgb(17 17 17 / 5%);
    transition:
      border-color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .products-catalog-callout__media {
    display: grid;
    min-height: 6.5rem;
    place-items: center;
    border-radius: var(--radius-sm);
    background: rgb(244 244 245 / 90%);
  }

  .products-catalog-callout__media img {
    width: min(100%, 8rem);
    max-height: 6rem;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .products-catalog-callout__copy {
    display: grid;
    gap: 0.25rem;
  }

  .products-catalog-callout__copy strong {
    font-size: clamp(1.05rem, 1.4vw, 1.35rem);
    line-height: 1.15;
  }

  .products-catalog-callout__copy span {
    max-width: 58rem;
    color: var(--color-gray-700);
    line-height: 1.5;
  }

  .products-catalog-callout__cta {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    border-radius: var(--radius-sm);
    padding: 0.7rem 0.9rem;
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    line-height: 1.15;
    white-space: nowrap;
    background: var(--color-orange-600);
  }

  .products-catalog-callout__cta :global(.site-icon) {
    filter: brightness(0) invert(1);
  }

  .products-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(6, 1fr);
  }

  .products-grid :global(.product-card--standard) {
    grid-column: span 2;
  }

  .products-grid :global(.product-card--featured) {
    grid-column: span 3;
  }

  .products-grid :global(.product-card--wide) {
    grid-column: 1 / -1;
  }

  @media (max-width: 63.99rem) {
    .products-catalog-callout {
      grid-template-columns: minmax(5rem, 7rem) minmax(0, 1fr);
    }

    .products-catalog-callout__cta {
      grid-column: 1 / -1;
      justify-self: start;
    }

    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .products-grid :global(.product-card--standard),
    .products-grid :global(.product-card--featured) {
      grid-column: span 1;
    }

    .products-grid :global(.product-card--wide) {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 40rem) {
    .products-section__header h2 {
      font-size: clamp(2.05rem, 11vw, 3rem);
    }

    .products-catalog-callout {
      grid-template-columns: 1fr;
    }

    .products-catalog-callout__media {
      min-height: 5.5rem;
    }

    .products-catalog-callout__cta {
      width: 100%;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }

    .products-grid :global(.product-card--standard),
    .products-grid :global(.product-card--featured),
    .products-grid :global(.product-card--wide) {
      grid-column: 1;
    }
  }
</style>
