---
import Icon from "@components/ui/Icon.astro";
import { getWhatsAppUrl } from "@lib/whatsapp";
import type { WhatsAppMessageKey } from "@data/whatsapp";

type Props = {
  id: string;
  category: string;
  categoryIcon: string;
  badge: string;
  badgeIcon: string;
  tone: "orange" | "pink" | "blue" | "brown";
  layout: "featured" | "standard" | "wide";
  title: string;
  description: string;
  image: string;
  alt: string;
  href: string;
  cta: string;
  message: WhatsAppMessageKey;
  highlights: readonly string[];
};

const {
  id,
  category,
  categoryIcon,
  badge,
  badgeIcon,
  tone,
  layout,
  title,
  description,
  image,
  alt,
  href,
  cta,
  message,
  highlights
} = Astro.props;

const showTopBadge = layout !== "standard";
---

<article id={id} class={`product-card product-card--${layout} product-card--${tone}`}>
  <div class="product-card__content">
    {
      showTopBadge && (
        <span class="product-card__badge">
          <Icon name={badgeIcon || categoryIcon} size="xs" />
          {badge}
        </span>
      )
    }
    <h3><a href={href}>{title}</a></h3>
    <p>{description}</p>
    {
      highlights.length > 0 && (
        <ul class="product-card__highlights" aria-label={`Destaques de ${title}`}>
          {highlights.map((item) => (
            <li>
              <Icon name="icon-check" size="xs" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      )
    }
    <a class="product-card__cta" href={getWhatsAppUrl(message)} target="_blank" rel="noopener noreferrer">
      <Icon name="icon-whatsapp" size="sm" />
      <span>{cta}</span>
      <span class="product-card__cta-arrow" aria-hidden="true">→</span>
    </a>
  </div>
  <a class="product-card__image-link" href={href} aria-label={title}>
    <img
      class="product-card__image"
      src={image}
      alt={alt}
      width="250"
      height="250"
      loading="lazy"
      decoding="async"
    />
  </a>
  {
    layout === "standard" && (
      <span class="product-card__category">
        <Icon name={categoryIcon} size="xs" />
        {category}
      </span>
    )
  }
</article>

<style>
  .product-card {
    position: relative;
    display: grid;
    border: 1px solid rgb(17 17 17 / 12%);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background:
      radial-gradient(circle at 72% 42%, rgb(249 115 22 / 8%), transparent 13rem),
      linear-gradient(180deg, var(--color-white), rgb(250 250 249 / 88%));
    box-shadow: 0 16px 42px rgb(17 17 17 / 5%);
    scroll-margin-top: calc(var(--header-height) + 3rem);
    transition: border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
  }

  .product-card:hover {
    transform: translateY(-2px);
    border-color: rgb(249 115 22 / 38%);
    box-shadow: 0 18px 48px rgb(17 17 17 / 8%);
  }

  .product-card__content {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    gap: var(--space-4);
    padding: var(--space-6);
  }

  .product-card__image-link {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    text-decoration: none;
  }

  .product-card__image {
    width: min(100%, 330px);
    max-width: none;
    height: auto;
    object-fit: contain;
    filter: saturate(1.03) contrast(1.03);
    transition: transform 180ms ease;
      mix-blend-mode: multiply;

  }

  .product-card:hover .product-card__image {
    transform: scale(1.025);
  }

  .product-card__badge,
  .product-card__category {
    display: inline-flex;
    width: max-content;
    max-width: 100%;
    align-items: center;
    gap: var(--space-2);
    border: 1px solid rgb(249 115 22 / 18%);
    border-radius: 4px;
    padding: 0.38rem 0.7rem;
    color: var(--color-orange-800);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    text-transform: uppercase;
    background: rgb(255 243 231 / 74%);
  }

  .product-card__badge :global(.site-icon),
  .product-card__category :global(.site-icon) {
    filter: brightness(0) saturate(100%) invert(46%) sepia(89%) saturate(1554%) hue-rotate(352deg) brightness(97%) contrast(91%);
  }

  .product-card h3 {
    margin: 0;
    color: var(--color-black);
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    line-height: 1.1;
  }

  .product-card h3 a {
    text-decoration: none;
  }

  .product-card h3 a:hover {
    color: var(--color-orange-700);
  }

  .product-card p {
    margin: 0;
    color: var(--color-gray-700);
    line-height: 1.55;
  }

  .product-card--featured {
    min-height: 430px;
    grid-template-columns: minmax(0, 1.08fr) minmax(12rem, 0.92fr);
    background:
      radial-gradient(circle at 78% 70%, rgb(249 115 22 / 12%), transparent 13rem),
      linear-gradient(135deg, var(--color-white), rgb(255 247 237 / 78%));
  }

  .product-card--featured .product-card__content {
    padding: clamp(1.5rem, 3vw, 2rem);
  }

  .product-card--featured h3 {
    font-size: clamp(2rem, 4vw, 3.1rem);
  }

  .product-card--featured .product-card__image-link {
    align-self: stretch;
    padding: var(--space-4) var(--space-5);
  }

  .product-card--featured .product-card__image {
    width: min(100%, 360px);
  }

  .product-card--standard {
    grid-template-rows: auto auto 1fr;
  }

  .product-card--standard .product-card__image-link {
    min-height: 230px;
    order: -2;
    background:
      linear-gradient(180deg, rgb(255 247 237 / 50%), rgb(255 255 255 / 0%));
  }

  .product-card--standard .product-card__image {
    width: 100%;
    max-height: 230px;
    object-fit: cover;
  }

  .product-card--standard .product-card__category {
    position: relative;
    z-index: 2;
    order: -1;
    margin: calc(var(--space-5) * -1) 0 0 var(--space-5);
    transform: translateY(-50%);
  }

  .product-card--standard .product-card__content {
    padding: 0 var(--space-5) var(--space-5);
  }

  .product-card--standard h3 {
    font-size: var(--text-xl);
  }

  .product-card--wide {
    min-height: 300px;
    grid-template-columns: minmax(18rem, 0.9fr) minmax(16rem, 1.1fr);
    align-items: stretch;
    border-style: dashed;
    background:
      linear-gradient(90deg, var(--color-white), rgb(255 247 237 / 74%)),
      var(--color-white);
  }

  .product-card--wide .product-card__content {
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }

  .product-card--wide .product-card__image-link {
    order: 2;
    align-self: stretch;
    min-height: 280px;
    background: rgb(255 247 237 / 42%);
  }

  .product-card--wide .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-card--wide h3 {
    font-size: clamp(1.8rem, 3.3vw, 2.7rem);
  }

  .product-card__highlights {
    display: grid;
    gap: var(--space-3);
    margin: var(--space-2) 0 0;
    padding: 0;
    list-style: none;
  }

  .product-card__highlights li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-gray-700);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
  }

  .product-card__highlights :global(.site-icon) {
    filter: brightness(0) saturate(100%) invert(46%) sepia(89%) saturate(1554%) hue-rotate(352deg) brightness(97%) contrast(91%);
  }

  .product-card__cta {
    display: grid;
    min-height: 54px;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
    margin-top: auto;
    border: 1px solid rgb(17 17 17 / 14%);
    border-radius: var(--radius-md);
    overflow: hidden;
    padding-left: var(--space-4);
    color: var(--color-gray-800);
    font-size: 0.82rem;
    font-weight: var(--font-weight-bold);
    text-decoration: none;
    text-transform: uppercase;
    background: rgb(255 255 255 / 88%);
  }

  .product-card--featured .product-card__cta,
  .product-card--wide .product-card__cta {
    max-width: 28rem;
  }

  .product-card__cta :global(.site-icon) {
    filter: brightness(0);
  }

  .product-card__cta-arrow {
    display: grid;
    width: 54px;
    align-self: stretch;
    place-items: center;
    color: var(--color-white);
    background: var(--color-orange-600);
    font-size: 1.3rem;
  }

  .product-card__cta:hover {
    border-color: var(--color-orange-600);
    color: var(--color-orange-800);
  }

  .product-card--pink {
    background:
      radial-gradient(circle at 76% 56%, rgb(236 72 153 / 14%), transparent 13rem),
      linear-gradient(135deg, var(--color-white), rgb(253 242 248 / 78%));
  }

  .product-card--pink .product-card__badge {
    border-color: rgb(236 72 153 / 18%);
    color: #be185d;
    background: rgb(253 242 248 / 88%);
  }

  .product-card--pink .product-card__badge :global(.site-icon) {
    filter: brightness(0) saturate(100%) invert(34%) sepia(92%) saturate(2334%) hue-rotate(306deg) brightness(94%) contrast(95%);
  }

  .product-card--pink .product-card__cta-arrow {
    background: #ec4899;
  }

  .product-card--blue .product-card__category {
    border-color: rgb(37 99 235 / 16%);
    color: #1d4ed8;
    background: rgb(239 246 255 / 84%);
  }

  .product-card--blue .product-card__category :global(.site-icon) {
    filter: brightness(0) saturate(100%) invert(31%) sepia(90%) saturate(1445%) hue-rotate(211deg) brightness(91%) contrast(91%);
  }

  .product-card--brown .product-card__category {
    border-color: rgb(146 64 14 / 14%);
    color: #92400e;
    background: rgb(254 243 199 / 58%);
  }

  .product-card--brown .product-card__category :global(.site-icon) {
    filter: brightness(0) saturate(100%) invert(28%) sepia(82%) saturate(760%) hue-rotate(356deg) brightness(96%) contrast(91%);
  }

  @media (max-width: 63.99rem) {
    .product-card--featured,
    .product-card--wide {
      grid-template-columns: 1fr;
    }

    .product-card--featured .product-card__image-link {
      order: -1;
      min-height: 260px;
    }

    .product-card--wide .product-card__image-link {
      order: 2;
      min-height: 260px;
    }

    .product-card--wide .product-card__image {
      height: auto;
      max-height: 320px;
      object-fit: cover;
    }
  }

  @media (max-width: 40rem) {
    .product-card__content {
      padding: var(--space-5);
    }

    .product-card--featured,
    .product-card--wide {
      min-height: auto;
    }

    .product-card--featured .product-card__image-link,
    .product-card--wide .product-card__image-link {
      min-height: 220px;
      padding: var(--space-4);
    }

    .product-card--featured h3,
    .product-card--wide h3 {
      font-size: clamp(1.65rem, 9vw, 2.35rem);
    }

    .product-card__cta {
      min-height: 52px;
      font-size: 0.78rem;
    }
  }
</style>
