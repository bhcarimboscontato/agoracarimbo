---
type Props = {
  name: string;
  label?: string;
  size?: "xs" | "sm" | "md" | "lg" | "xl";
  decorative?: boolean;
};

const { name, label = "", size = "sm", decorative = true } = Astro.props;

const iconSizes = {
  xs: 16,
  sm: 20,
  md: 24,
  lg: 32,
  xl: 40
} as const;

const pixelSize = iconSizes[size];
const accessibilityProps = decorative
  ? { alt: "", "aria-hidden": true }
  : { alt: label };
---

<img
  class={`site-icon site-icon--${size}`}
  src={`/assets/icones/${name}.svg`}
  width={pixelSize}
  height={pixelSize}
  style={`--icon-size: ${pixelSize}px;`}
  loading="lazy"
  decoding="async"
  {...accessibilityProps}
/>
