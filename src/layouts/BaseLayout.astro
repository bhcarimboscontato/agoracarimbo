---
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import CookieConsent from "@components/ui/CookieConsent.astro";
import SeoHead from "@components/seo/SeoHead.astro";
import { brandAssets } from "@data/site";
import {
  getLocalBusinessSchema,
  getOrganizationSchema,
  getWebPageSchema,
  getWebSiteSchema
} from "@lib/seo";
import "@styles/global.css";

type Props = {
  title: string;
  description: string;
  canonicalPath: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown>[];
};

const { title, description, canonicalPath, noindex = false, structuredData = [] } = Astro.props;
const organizationSchema = getOrganizationSchema();
const webSiteSchema = getWebSiteSchema();
const webPageSchema = getWebPageSchema({ title, description, canonicalPath });
const localBusinessSchema = getLocalBusinessSchema();
const schemas = [organizationSchema, webSiteSchema, localBusinessSchema, webPageSchema, ...structuredData];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      noindex={noindex}
    />

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=AW-11538800483"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag("js", new Date());

  gtag("config", "AW-11538800483");
</script>

<script is:inline>
  window.gtag_report_conversion = function (url) {
    const callback = function () {
      if (typeof url !== "undefined") {
        window.location = url;
      }
    };

    if (typeof window.gtag === "function") {
      window.gtag("event", "conversion", {
        send_to: "AW-11538800483/GKFtCMKMvb4aEOO-kP4q",
        value: 2.0,
        currency: "BRL",
        event_callback: callback
      });

      setTimeout(callback, 800);
      return false;
    }

    callback();
    return false;
  };

  document.addEventListener("click", function (event) {
    const target = event.target;
    const link = target instanceof Element ? target.closest("a") : null;

    if (!link) return;

    const href = link.getAttribute("href") || "";
    const isWhatsAppLink =
      href.includes("wa.me/") ||
      href.includes("api.whatsapp.com") ||
      href.includes("web.whatsapp.com") ||
      link.dataset.conversion === "whatsapp";

    if (!isWhatsAppLink) return;

    event.preventDefault();
    window.gtag_report_conversion(link.href);
  });
</script>

    <link rel="icon" href={brandAssets.favicon} sizes="any" />
    <link rel="apple-touch-icon" href={brandAssets.appleTouchIcon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    {schemas.map((schema) => <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />)}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
